{
  "downstream": {
    "transport": "stdio",
    "port": 8080,
    "host": "127.0.0.1",
    "allowedOrigins": []
  },
  "upstream": {
    "transport": "stdio",
    "command": ["node", "server.js"],
    "env": {
      "NODE_ENV": "production",
      "API_KEY": "set-me-via-secret-manager"
    }
  },
  "profile": "auto",
  "policy": "strict",
  "envAllowlist": [],
  "timeoutMs": 30000,
  "maxMessageSize": 1048576,
  "maxHttpBodySize": 4194304,
  "logging": "normal",
  "toolInclude": null,
  "toolExclude": null
}
